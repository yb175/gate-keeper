# Gatekeeper API Server configuration
PORT=3001

# LLM Providers Configuration
# At least GEMINI_API_KEY or GROK_API_KEY must be provided, or set MOCK_LLM=true for local testing.
GEMINI_API_KEY=your-gemini-api-key-here
GROK_API_KEY=your-grok-api-key-here

# Optional: LLM configuration
GEMINI_TIMEOUT_MS=30000
GROK_MODEL=grok-2-1212

# Mock Mode: Set to true to run the API without hitting real LLM endpoints (uses mock logic in apps/api/src/agent/llm.ts)
MOCK_LLM=false

# Optional Upstash Context7 API Key for documentation lookup
# Required only if you want the context7 plugin to query external documentation libraries
CONTEXT7_API_KEY=your-upstash-context7-api-key-here